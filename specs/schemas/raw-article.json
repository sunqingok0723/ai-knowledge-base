{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-knowledge-base/specs/schemas/raw-article.json",
  "title": "RawArticle",
  "description": "Collector Agent 输出的原始采集数据格式",
  "type": "object",
  "required": ["title", "url", "source", "popularity", "summary"],
  "properties": {
    "title": {
      "type": "string",
      "description": "项目名称",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "description": "GitHub 仓库链接",
      "format": "uri",
      "pattern": "^https://github\\.com/"
    },
    "source": {
      "type": "string",
      "description": "数据来源标识",
      "enum": ["github_trending", "hacker_news"]
    },
    "popularity": {
      "type": "integer",
      "description": "热度指标（stars 数或今日增量）",
      "minimum": 0
    },
    "summary": {
      "type": "string",
      "description": "项目原始描述（英文）",
      "minLength": 1
    }
  }
}
